# gitlab-pipeline-stats — config
#
# Copy to .env and fill in:
#   cp .env.example .env

# GitLab host without a trailing slash.
# Optional: inside GitLab CI taken from CI_SERVER_URL,
# inside a cloned repository taken from `git remote get-url origin`.
GITLAB_HOST=https://gitlab.example.com

# Personal Access Token with scope `read_api`
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Optional:
# Path to a JSON config describing pipeline groups.
# Bundled preset names are no longer accepted — dump the one you want into a file:
#   gitlab-pipeline-stats init gitflow > gitlab-pipeline-stats.json
# If this variable is not set, the tool looks for ./gitlab-pipeline-stats.json in cwd.
GITLAB_PIPELINE_STATS_CONFIG=./gitlab-pipeline-stats.json

# How many recent pipelines to fetch per group (default: 50, max: 100)
PIPELINE_LIMIT=50

# Job status filter (empty — no filter).
# Usually `success` is what you want, to skip failed runs / retries.
JOB_STATUS_FILTER=success
