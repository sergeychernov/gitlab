# gitlab-pipeline-stats — конфиг
#
# Скопировать в .env и заполнить:
#   cp .env.example .env

# Хост GitLab без завершающего слеша.
# Опционально: внутри GitLab CI берётся из CI_SERVER_URL,
# а внутри клонированного репозитория — из git remote get-url origin.
GITLAB_HOST=https://gitlab.example.com

# Personal Access Token со scope `read_api`
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Опционально:
# Пресет групп пайплайнов: gitflow | github-flow | trunk | tags-flow
# Либо путь к своему JSON-файлу. По умолчанию — gitflow.
GITLAB_PIPELINE_STATS_CONFIG=gitflow

# Сколько последних пайплайнов забрать в каждой группе (default: 50, max 100)
PIPELINE_LIMIT=50

# Фильтр по статусу джобы (пусто — без фильтра).
# Обычно интересует success, чтобы не учитывать аварийные/ретраи.
JOB_STATUS_FILTER=success
