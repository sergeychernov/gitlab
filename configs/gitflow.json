{
    "$schema": "../schemas/config.schema.json",
    "description": "Git Flow: main, develop, release/*, feature/*, hotfix/*, tags",
    "groups": [
        { "label": "main",       "ref": "main" },
        { "label": "develop",    "ref": "develop" },
        { "label": "release/*",  "scope": "branches", "refPattern": "^release/" },
        { "label": "feature/*",  "scope": "branches", "refPattern": "^feature/" },
        { "label": "hotfix/*",   "scope": "branches", "refPattern": "^hotfix/" },
        { "label": "tags",       "scope": "tags" }
    ]
}
