{
    "name": "gitlab-pipeline-stats",
    "version": "1.1.1",
    "description": "Quick GitLab pipeline stats: avg, p50, p95, and max per job and group. Groups are configured via presets for different release flows.",
    "type": "module",
    "bin": "./dist/gitlab-pipeline-stats.js",
    "files": [
        "dist/",
        "configs/",
        "share/"
    ],
    "engines": {
        "node": ">=20"
    },
    "packageManager": "yarn@4.13.0",
    "scripts": {
        "typecheck": "tsc --noEmit",
        "test": "node --test test/*.test.ts",
        "build": "tsc && node -e \"import('node:fs').then(fs => fs.chmodSync('dist/gitlab-pipeline-stats.js', 0o755))\"",
        "prepublishOnly": "yarn build"
    },
    "devDependencies": {
        "@types/node": "^24.0.0",
        "typescript": "^5.7.0"
    },
    "keywords": [
        "gitlab",
        "pipeline",
        "stats",
        "ci",
        "devops",
        "gitflow",
        "github-flow",
        "trunk-based"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sergeychernov/gitlab.git"
    },
    "homepage": "https://github.com/sergeychernov/gitlab#readme",
    "bugs": {
        "url": "https://github.com/sergeychernov/gitlab/issues"
    },
    "license": "MIT"
}
